# ─────────────────────────────────────────────────────────────────────────────
# ETL Pipeline API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000
APP_NAME=ETL Pipeline API

# File Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls

# Database Settings
# For SQLite (local development)
DATABASE_URL=sqlite:///./etl_pipeline.db

# For PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/etl_db

# For MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/etl_db

# Processing Settings
MAX_WORKERS=4
PROCESSING_TIMEOUT=3600

# Security Settings
SECRET_KEY=your-super-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
